APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/rebel_forge

WORKER_POLL_INTERVAL_SECONDS=2
DEFAULT_WORKSPACE_NAME=Primary Workspace

LLM_PROVIDER=openai_responses
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_MODEL=openai/gpt-oss-120b
LLM_API_KEY=
LLM_MAX_OUTPUT_TOKENS=32000

MEDIA_PROVIDER=openai_images
MEDIA_BASE_URL=http://127.0.0.1:8001/v1
MEDIA_MODEL=gpt-image-1
MEDIA_API_KEY=
MEDIA_IMAGE_SIZE=1024x1024
MEDIA_RESPONSE_FORMAT=b64_json

STORAGE_BACKEND=local
STORAGE_BASE_PATH=./data/assets
PUBLIC_ASSET_BASE_URL=http://localhost:8080/assets

FIRECRAWL_API_KEY=your-firecrawl-api-key
FIRECRAWL_API_URL=https://api.firecrawl.dev

X_CONSUMER_KEY=your-x-consumer-key
X_CONSUMER_SECRET=your-x-consumer-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_TOKEN_SECRET=your-x-access-token-secret

LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_PERSON_ID=your-linkedin-person-id

FACEBOOK_ACCESS_TOKEN=your-facebook-access-token
FACEBOOK_PAGE_ID=your-facebook-page-id
FACEBOOK_PAGE_TOKEN=your-facebook-page-token

INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_USER_ID=your-instagram-user-id

THREADS_ACCESS_TOKEN=your-threads-access-token
THREADS_USER_ID=your-threads-user-id

R2_ENDPOINT_URL=your-r2-endpoint
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=rebel-forge
R2_PUBLIC_URL=your-r2-public-url
